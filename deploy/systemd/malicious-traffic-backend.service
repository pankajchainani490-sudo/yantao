[Unit]
Description=Malicious Traffic ML FastAPI Backend
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/malicious-traffic-ml/backend
EnvironmentFile=/opt/malicious-traffic-ml/deploy/ubuntu/backend.env
ExecStart=/opt/malicious-traffic-ml/backend/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
